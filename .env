
# ==============================================
# A股基础设置
# ==============================================
# 关注的股票代码（示例：贵州茅台600519、宁德时代300750）
STOCK_LIST=601012,600366,002506,002050

# ==============================================
# 数据源（A股必须填 Tushare）
# ==============================================
# Tushare Token（免费获取：https://tushare.pro/）
TUSHARE_TOKEN=f42e815b132377659c42f6d8fdb1d7e58355150dfa417c4bbd3847fan

# ==============================================
# 定时任务（自动抓取分析）
# ==============================================
SCHEDULE_ENABLED=true
SCHEDULE_TIME=09:00
SCHEDULE_RUN_IMMEDIATELY=true
TRADING_DAY_CHECK_ENABLED=true

# ==============================================
# 阿里云百炼 API 配置（核心修改区）
# ==============================================
# 1. 模型名称：根据你部署的模型名填（如 qwen-max、deepseek-v3 等）
LLM_MODEL=qwen-max
# 2. API Key：就是你截图里的 sk-xxxxxxx
API_KEY=sk-db79e9c6c53147a5b3374bb333f0349e
# 3. 阿里云百炼端点（北京/上海等，默认通用）
API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
